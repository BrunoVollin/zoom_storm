// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id              String @id
  name            String
  price           Float
  description     String
  category        String
  stock           Int
  transportHeight Int
  transportWidth  Int
  transportLength Int
}

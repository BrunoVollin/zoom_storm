{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "esModuleInterop": true,
    "types": [
      "node",
      "jest"
    ],
    "skipLibCheck": true,
    "isolatedModules": true,
    "paths": {
      "@src/*": [
        "apps/cart-service/src/*"
      ],
      "@domain/*": [
        "apps/cart-service/src/domain/*"
      ],
      "@application/*": [
        "apps/cart-service/src/application/*"
      ],
      "@infrastructure/*": [
        "apps/cart-service/src/infrastructure/*"
      ],
      "@cart-projection/*": [
        "apps/cart-projection/src/*"
      ]
    }
  }
}